[http]
enabled = false
doc_root = /usr/share/snapserver/snapweb

[tcp-control]
enabled = true
bind_to_address = 0.0.0.0
port = 1705

[tcp-streaming]
enabled = true
bind_to_address = 0.0.0.0
port = 1704

[stream]
source = pipe:///tmp/snapfifo?name=default
sampleformat = 44100:16:2
codec = flac
chunk_ms = 26
buffer = 150

[streaming_client]
initial_volume = 100
timeout = 30000

[logging]
sink = stdout
filter = *:info
